NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/ehr
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=8h
PHI_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# CORS_ORIGIN=http://localhost:5173 - for local development, uncomment and set to your frontend URL
CORS_ORIGIN=https://omii-ehr.vercel.app/

# AI assistant (Groq). Leave GROQ_API_KEY empty to disable the assistant entirely.
# Get a key at https://console.groq.com . Do NOT send real PHI without a signed BAA.
GROQ_API_KEY=abcde
AGENT_MODEL=llama-3.3-70b-versatile
# AGENT_BASE_URL=https://api.groq.com/openai/v1
# INTERNAL_API_BASE_URL=http://127.0.0.1:4000

